    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.13.1",
    "prisma": "^6.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14",
    "supertest": "^7.0.0",
