    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "zod": "^3.24.1",
    "dotenv": "^16.4.7",
    "@prisma/client": "^6.4.0",
    "@neondatabase/serverless": "^0.10.4",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.8",
