PORT=4000
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Neon PostgreSQL — get from neon.tech dashboard
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=change-me-min-32-chars-random-string-here
JWT_REFRESH_SECRET=change-me-different-min-32-chars-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Upstash Redis — get from console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Resend — get from resend.com dashboard
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=noreply@yourdomain.com

# Uploadthing — get from uploadthing.com dashboard (App API Key)
UPLOADTHING_SECRET=sk_live_your_uploadthing_secret_key

# Google Calendar OAuth — get from console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/meetings/oauth/callback
