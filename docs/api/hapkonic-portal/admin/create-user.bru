meta {
  name: Create User
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/admin/users
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "email": "newclient@example.com",
    "name": "New Client User",
    "role": "client",
    "clientId": "{{clientId}}",
    "password": "TempPass@123"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("userId", res.body.user.id)
  }
}
